{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "react": ["./packages/web/node_modules/react"],
      "react/*": ["./packages/web/node_modules/react/*"],
      "@tanstack/react-query": ["./packages/web/node_modules/@tanstack/react-query"],
      "@tanstack/react-table": ["./packages/web/node_modules/@tanstack/react-table"],
      "@dnd-kit/core": ["./packages/web/node_modules/@dnd-kit/core"],
      "@dnd-kit/sortable": ["./packages/web/node_modules/@dnd-kit/sortable"],
      "@dnd-kit/utilities": ["./packages/web/node_modules/@dnd-kit/utilities"],
      "@fullcalendar/react": ["./packages/web/node_modules/@fullcalendar/react"],
      "@fullcalendar/daygrid": ["./packages/web/node_modules/@fullcalendar/daygrid"],
      "@fullcalendar/core": ["./packages/web/node_modules/@fullcalendar/core"],
      "@fullcalendar/timegrid": ["./packages/web/node_modules/@fullcalendar/timegrid"],
      "@fullcalendar/interaction": ["./packages/web/node_modules/@fullcalendar/interaction"],
      "gantt-task-react": ["./packages/web/node_modules/gantt-task-react"],
      "zustand": ["./packages/web/node_modules/zustand"],
      "hono": ["./packages/api/node_modules/hono"],
      "hono/*": ["./packages/api/node_modules/hono/*"],
      "@supabase/supabase-js": ["./packages/api/node_modules/@supabase/supabase-js"],
      "@/*": ["./src/*"]
    },
    "typeRoots": [
      "./packages/web/node_modules/@types",
      "./node_modules/@types"
    ]
  },
  "include": ["src", "api"]
}
